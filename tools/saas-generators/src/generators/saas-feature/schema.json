{
  "$schema": "https://json-schema.org/schema",
  "$id": "SaasFeature",
  "title": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the feature module",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },
    "directory": {
      "type": "string",
      "description": "Directory where to place the feature module (e.g. features/web-entwicklung)"
    }
  },
  "required": ["name"]
}
